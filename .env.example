# ══════════════════════════════════════════════════════════
#  BTC 15m Quant — Environment Variables
# ══════════════════════════════════════════════════════════
# Copy to .env for local dev. Set as Railway env vars in production.

# ─── REQUIRED ─────────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=0xYOUR_POLYGON_PRIVATE_KEY

# ─── POLYMARKET API CREDENTIALS ───────────────────────────
# Leave blank on first run — the bot will print them to logs.
# Then set them here and restart.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ─── BINANCE (optional — public endpoints work without keys) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── COINBASE (optional — public candle endpoint needs no key) ─
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ─── POLYGON RPC (IMPORTANT for wallet balance) ─────────
# Required for accurate USDC balance display.
# Use a free Alchemy/Infura/QuickNode Polygon mainnet RPC URL.
POLYGON_RPC_URL=
# Polymarket uses USDC.e (bridged) on Polygon — this is the correct contract:
POLYGON_USDC_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174

# ─── TELEGRAM ────────────────────────────────────────────
# 1. Create bot: @BotFather → /newbot
# 2. Get chat ID: curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── MISC ────────────────────────────────────────────────
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./state.db
